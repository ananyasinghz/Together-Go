# Copy to .env and fill in values (never commit .env with secrets).

# MongoDB connection string (local: mongodb://127.0.0.1:27017)
MONGO_URL=mongodb://127.0.0.1:27017

# Database name — use a separate name for automated tests, e.g. together_go_test
DB_NAME=together_go

# Comma-separated origins for CORS (browser frontend URLs)
CORS_ORIGINS=http://localhost:3000

# Frontend: create frontend/.env with:
# REACT_APP_BACKEND_URL=http://localhost:8000
